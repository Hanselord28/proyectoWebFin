<!DOCTYPE html>
<html lang="es">

<%- include ('../partials/head') %>

<body class="d-flex flex-column min-vh-100 bg-light">

    
    <%- include ('../partials/navbar') %>

    <div class="container mt-4 mb-5">
        <h2 class="mb-4 text-primary fw-bold d-flex align-items-center gap-2">
            Hola, <%= nombreUsuario %> <span class="material-symbols-outlined fs-2 text-warning">waving_hand</span>
        </h2>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">event_available</span>
                        <h5 class="card-title fw-bold text-secondary mb-0">Próximas Citas</h5>
                    </div>
                    <div class="card-body">
                        <% if (citas.length > 0) { %>
                            <div class="list-group list-group-flush">
                                <% citas.forEach(cita => { %>
                                    <div class="list-group-item px-0 py-3">
                                        <div class="d-flex w-100 justify-content-between mb-1">
                                            <h6 class="mb-0 fw-bold"><%= cita.procedimiento %></h6>
                                            <span class="badge bg-warning text-dark rounded-pill">Pendiente</span>
                                        </div>
                                        <p class="mb-1 text-muted small d-flex align-items-center gap-1">
                                            <span class="material-symbols-outlined fs-6">schedule</span> 
                                            <%= new Date(cita.fecha).toLocaleDateString('es-ES') %> a las <%= cita.hora.substring(0, 5) %> hrs
                                        </p>
                                        <small class="text-muted d-flex align-items-center gap-1 mb-3">
                                            <span class="material-symbols-outlined fs-6">stethoscope</span> Dr/a. <%= cita.doc_nombre %> <%= cita.doc_apellidos %>
                                        </small>
                                        <div class="text-end">
                                            <form action="/paciente/citas/cancelar/<%= cita.id_cita %>" method="POST" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta cita? No podrás deshacer esta acción.');">
                                                <button type="submit" class="btn btn-outline-danger btn-sm d-inline-flex align-items-center gap-1">
                                                    <span class="material-symbols-outlined fs-6">cancel</span> Cancelar Cita
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5 text-muted">
                                <span class="material-symbols-outlined display-4 d-block mb-3 opacity-50">event_busy</span>
                                <p>No tienes citas programadas.</p>
                                <a href="/citas/nueva" class="btn btn-primary btn-sm mt-2 d-inline-flex align-items-center gap-1">
                                    <span class="material-symbols-outlined fs-6">calendar_add_on</span> Agendar ahora
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">clinical_notes</span>
                        <h5 class="card-title fw-bold text-secondary mb-0">Historial Clínico</h5>
                    </div>
                    <div class="card-body">
                        <% if (historial.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light text-muted small">
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Procedimiento</th>
                                            <th>Diagnóstico & Tratamiento</th>
                                            <th>Presupuesto</th>
                                        </tr>
                                    </thead>
                                    <tbody class="small">
                                        <% historial.forEach(registro => { %>
                                            <tr>
                                                <td class="text-nowrap fw-semibold">
                                                    <%= new Date(registro.fecha_registro).toLocaleDateString('es-ES') %>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary"><%= registro.procedimiento || 'General' %></span>
                                                </td>
                                                <td>
                                                    <strong>Diag:</strong> <%= registro.diagnostico %><br>
                                                    <span class="text-muted"><strong>Tratamiento:</strong> <%= registro.tratamiento_realizado %></span>
                                                </td>
                                                <td>
                                                    <% if(registro.presupuesto && registro.presupuesto > 0) { %>
                                                        <span class="text-success fw-bold">$<%= Number(registro.presupuesto).toLocaleString('es-CL') %></span>
                                                    <% } else { %>
                                                        <span class="text-muted">-</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5 text-muted">
                                <span class="material-symbols-outlined display-4 d-block mb-3 opacity-50">history_toggle_off</span>
                                <p>Aún no tienes registros en tu historial clínico.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </div>
    
    <%- include ('../partials/footer') %>

</body>
</html>