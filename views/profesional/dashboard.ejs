<!DOCTYPE html>
<html lang="es">

<%- include ('../partials/head') %>

<body class="d-flex flex-column min-vh-100 bg-light">

    <nav class="navbar navbar-dark bg-info shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/profesional/dashboard">
                <span class="material-symbols-outlined">stethoscope</span>
                Panel Clínico
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-dark fw-bold d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-5">person</span> Dr/a. <%= nombreDoc %>
                </span>
                <a href="/auth/logout" class="btn btn-outline-dark btn-sm d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-6">logout</span> Cerrar Sesión
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="row g-4">

            <div class="col-lg-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-info">event_upcoming</span>
                        <h5 class="fw-bold text-secondary mb-0">Mis Citas Pendientes</h5>
                    </div>
                    <div class="card-body">
                        <% if(citas.length > 0) { %>
                            <div class="list-group list-group-flush">
                                <% citas.forEach(cita => { %>
                                    <div class="list-group-item px-0 py-3">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1 fw-bold text-dark"><%= cita.paciente_nombre %> <%= cita.paciente_apellidos %></h6>
                                            <small class="text-info fw-bold d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">schedule</span> <%= cita.hora.substring(0, 5) %> hrs
                                            </small>
                                        </div>
                                        <p class="mb-1 small text-muted d-flex align-items-center gap-1">
                                            <span class="material-symbols-outlined fs-6">dentistry</span> <%= cita.procedimiento %>
                                        </p>
                                        <small class="text-muted"><strong>RUT:</strong> <%= cita.rut %> | <strong>Fecha:</strong> <%= new Date(cita.fecha).toLocaleDateString('es-ES') %></small>
                                        <div class="mt-2 text-end">
                                            <a href="/profesional/consulta/<%= cita.id_cita %>" class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">medical_services</span> Atender Cita
                                            </a>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center text-muted my-5">
                                <span class="material-symbols-outlined display-4 opacity-25 d-block mb-2">event_available</span>
                                <p>No tienes citas agendadas por el momento.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card shadow-sm border-0 mb-4 bg-info bg-opacity-10">
                    <div class="card-body">
                        <h5 class="fw-bold text-secondary mb-3 d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined">search</span> Buscar Historial de Paciente
                        </h5>
                        <form action="/profesional/dashboard" method="GET" class="d-flex">
                            <input type="text" class="form-control me-2" name="rut" placeholder="Ingrese el RUT (Ej: 12.345.678-9)" value="<%= rutBuscado || '' %>" required>
                            <button type="submit" class="btn btn-info text-white fw-bold d-flex align-items-center justify-content-center gap-1">
                                <span class="material-symbols-outlined fs-6">search</span> Buscar
                            </button>
                            <a href="/profesional/dashboard" class="btn btn-outline-secondary ms-2 d-flex align-items-center justify-content-center gap-1">
                                <span class="material-symbols-outlined fs-6">backspace</span> Limpiar
                            </a>
                        </form>
                    </div>
                </div>

                <% if(rutBuscado) { %>
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <% if(paciente) { %>
                                <h5 class="fw-bold text-primary border-bottom pb-2 mb-3 d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined">patient_list</span> Ficha Clínica: <%= paciente.nombre %> <%= paciente.apellidos %>
                                </h5>
                                <div class="row mb-4 small">
                                    <div class="col-sm-6 d-flex align-items-center gap-1"><span class="material-symbols-outlined fs-6 text-muted">badge</span><strong>RUT:</strong> <%= paciente.rut %></div>
                                    <div class="col-sm-6 d-flex align-items-center gap-1"><span class="material-symbols-outlined fs-6 text-muted">health_and_safety</span><strong>Previsión:</strong> <%= paciente.prevision %></div>
                                    <div class="col-sm-6 mt-2 d-flex align-items-center gap-1"><span class="material-symbols-outlined fs-6 text-muted">call</span><strong>Teléfono:</strong> <%= paciente.telefono %></div>
                                    <div class="col-sm-6 mt-2 d-flex align-items-center gap-1"><span class="material-symbols-outlined fs-6 text-muted">mail</span><strong>Correo:</strong> <%= paciente.correo %></div>
                                </div>

                                <h6 class="fw-bold text-secondary mb-3 d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-5">clinical_notes</span> Historial de Tratamientos
                                </h6>
                                <% if(historial.length > 0) { %>
                                    <div class="table-responsive">
                                        <table class="table table-hover table-sm align-middle small">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Fecha</th>
                                                    <th>Procedimiento</th>
                                                    <th>Diagnóstico / Notas</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% historial.forEach(registro => { %>
                                                    <tr>
                                                        <td class="text-nowrap"><%= new Date(registro.fecha_registro).toLocaleDateString('es-ES') %></td>
                                                        <td><span class="badge bg-secondary"><%= registro.procedimiento || 'General' %></span></td>
                                                        <td>
                                                            <strong>D:</strong> <%= registro.diagnostico %><br>
                                                            <span class="text-muted"><strong>T:</strong> <%= registro.tratamiento_realizado %></span>
                                                            <% if(registro.observaciones) { %>
                                                                <br><small class="text-muted"><strong>Obs:</strong> <%= registro.observaciones %></small>
                                                            <% } %>
                                                            <% if(registro.presupuesto && registro.presupuesto > 0) { %>
                                                                <br><small class="text-success fw-bold">Presupuesto: $<%= Number(registro.presupuesto).toLocaleString('es-CL') %></small>
                                                            <% } %>
                                                            <% if(registro.doc_nombre) { %>
                                                                <br><small class="text-info"><strong>Atendido por:</strong> Dr/a. <%= registro.doc_nombre %> <%= registro.doc_apellidos %></small>
                                                            <% } %>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                <% } else { %>
                                    <p class="text-muted d-flex align-items-center gap-1">
                                        <span class="material-symbols-outlined fs-6">history_toggle_off</span> El paciente no tiene registros clínicos anteriores.
                                    </p>
                                <% } %>

                                <div class="mt-3">
                                    <button class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1">
                                        <span class="material-symbols-outlined fs-6">note_add</span> Añadir Registro Clínico
                                    </button>
                                </div>
                            <% } else { %>
                                <div class="alert alert-warning mb-0 d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined">person_off</span> 
                                    <div>No se encontró ningún paciente con el RUT: <strong><%= rutBuscado %></strong></div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>

        </div>
    </div>

    <%- include ('../partials/footer') %>
</body>
</html>