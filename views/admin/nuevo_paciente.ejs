<%- include ('../partials/head') %>
<%- include ('../partials/navbar') %>

<div class="container mt-5 mb-5 d-flex flex-column min-vh-100">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined">person_add</span>
                    <h4 class="mb-0">Registrar Nuevo Paciente</h4>
                </div>

                <div class="card-body p-4">
                    <form action="/admin/pacientes/nuevo" method="POST">

                        <h6 class="text-muted fw-bold mb-3 border-bottom pb-2">Datos Personales</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Nombre</label>
                                <div class="input-group">
                                    <span class="input-group-text"><span class="material-symbols-outlined fs-5">person</span></span>
                                    <input type="text" class="form-control" name="nombre" placeholder="Ej: Juan" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Apellidos</label>
                                <div class="input-group">
                                    <span class="input-group-text"><span class="material-symbols-outlined fs-5">person</span></span>
                                    <input type="text" class="form-control" name="apellidos" placeholder="Ej: Pérez" required>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">RUT</label>
                                <div class="input-group">
                                    <span class="input-group-text"><span class="material-symbols-outlined fs-5">badge</span></span>
                                    <input type="text" class="form-control" name="rut" placeholder="12345678-9" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Previsión de Salud</label>
                                <div class="input-group">
                                    <span class="input-group-text"><span class="material-symbols-outlined fs-5">health_and_safety</span></span>
                                    <select class="form-select" name="prevision" required>
                                        <option value="" disabled selected>Seleccione...</option>
                                        <option value="Fonasa">Fonasa</option>
                                        <option value="Isapre">Isapre</option>
                                        <option value="Particular">Particular</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <h6 class="text-muted fw-bold mb-3 border-bottom pb-2">Contacto y Cuenta</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Teléfono</label>
                                <div class="input-group">
                                    <span class="input-group-text"><span class="material-symbols-outlined fs-5">call</span></span>
                                    <input type="tel" class="form-control" name="telefono" placeholder="+56 9 1234 5678" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold">Correo Electrónico</label>
                                <div class="input-group">
                                    <span class="input-group-text"><span class="material-symbols-outlined fs-5">mail</span></span>
                                    <input type="email" class="form-control" name="correo" placeholder="correo@ejemplo.com" required>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted fw-bold">Contraseña Temporal</label>
                            <div class="input-group">
                                <span class="input-group-text"><span class="material-symbols-outlined fs-5">lock</span></span>
                                <input type="password" class="form-control" name="password" placeholder="Asigne una contraseña inicial" required>
                            </div>
                            <div class="form-text">El paciente utilizará esta contraseña y su correo para iniciar sesión.</div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/admin/dashboard" class="btn btn-secondary d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined">arrow_back</span> Cancelar
                            </a>
                            <button type="submit" class="btn btn-success d-flex align-items-center gap-1">
                                <span class="material-symbols-outlined">save</span> Registrar Paciente
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include ('../partials/footer') %>