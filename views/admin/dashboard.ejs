<!DOCTYPE html>
<html lang="es">
<head>
    <%- include ('../partials/head') %>
    <title>Panel Administrador | Clínica Dental</title>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <nav class="navbar navbar-dark bg-dark shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold" href="/admin/dashboard"><i class="bi bi-shield-lock me-2"></i>Admin Panel - Clínica Dental España</a>
            <div class="d-flex align-items-center">
                <span class="text-light me-3">Hola, <%= nombreAdmin %></span>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm">Cerrar Sesión</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-secondary">Tablero General</h2>
            <div>
                <a href="#" class="btn btn-success me-2"><i class="bi bi-person-plus me-1"></i>Nuevo Paciente</a>
                <a href="#" class="btn btn-primary"><i class="bi bi-person-vcard me-1"></i>Nuevo Profesional</a>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-primary text-white h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75">Citas Pendientes</h6>
                            <h2 class="display-5 fw-bold mb-0"><%= stats.citasPendientes %></h2>
                        </div>
                        <i class="bi bi-calendar-event display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-success text-white h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75">Pacientes Registrados</h6>
                            <h2 class="display-5 fw-bold mb-0"><%= stats.pacientes %></h2>
                        </div>
                        <i class="bi bi-people display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-info text-white h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75">Profesionales</h6>
                            <h2 class="display-5 fw-bold mb-0"><%= stats.profesionales %></h2>
                        </div>
                        <i class="bi bi-heart-pulse display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white pt-4 pb-3 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-secondary mb-0">Gestión de Citas</h5>
                <a href="/citas/nueva" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-lg"></i> Agendar Cita Manual</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha y Hora</th>
                                <th>Paciente</th>
                                <th>Procedimiento</th>
                                <th>Profesional</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(citas.length > 0) { %>
                                <% citas.forEach(cita => { %>
                                    <tr>
                                        <td>
                                            <strong><%= new Date(cita.fecha).toLocaleDateString('es-ES') %></strong><br>
                                            <small class="text-muted"><%= cita.hora.substring(0, 5) %> hrs</small>
                                        </td>
                                        <td><%= cita.paciente_nombre %> <%= cita.paciente_apellidos %></td>
                                        <td><%= cita.procedimiento %></td>
                                        <td>Dr/a. <%= cita.doc_apellidos %></td>
                                        <td>
                                            <% if(cita.estado === 'pendiente') { %>
                                                <span class="badge bg-warning text-dark">Pendiente</span>
                                            <% } else if(cita.estado === 'completada') { %>
                                                <span class="badge bg-success">Completada</span>
                                            <% } else { %>
                                                <span class="badge bg-danger">Cancelada</span>
                                            <% } %>
                                        </td>
                                        <td class="text-center">
                                            <a href="/admin/citas/editar/<%= cita.id_cita %>" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
                                            <form action="/admin/citas/eliminar/<%= cita.id_cita %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="return confirm('¿Seguro que deseas eliminar esta cita?')"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No hay citas registradas en el sistema.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include ('../partials/footer') %>
</body>
</html>