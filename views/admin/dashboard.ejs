<!DOCTYPE html>
<html lang="es">
<head>
    <%- include ('../partials/head') %>
    <title>Panel Administrador | Clínica Dental</title>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <nav class="navbar navbar-dark bg-dark shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/admin/dashboard">
                <span class="material-symbols-outlined">admin_panel_settings</span>
                Admin Panel - Clínica Dental España
            </a>
            <div class="d-flex align-items-center">
                <span class="text-light me-3">Hola, <%= nombreAdmin %></span>
                <a href="/auth/logout" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-6">logout</span> Cerrar Sesión
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-secondary">Tablero General</h2>
            <div class="d-flex gap-2">
                <a href="/admin/pacientes/nuevo" class="btn btn-success d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-5">person_add</span> Nuevo Paciente
                </a>
                <a href="/admin/profesionales/nuevo" class="btn btn-primary d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-5">medical_information</span> Nuevo Profesional
                </a>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-primary text-white h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75">Citas Pendientes</h6>
                            <h2 class="display-5 fw-bold mb-0"><%= stats.citasPendientes %></h2>
                        </div>
                        <span class="material-symbols-outlined display-4 opacity-50">event_upcoming</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-success text-white h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75">Pacientes Registrados</h6>
                            <h2 class="display-5 fw-bold mb-0"><%= stats.pacientes %></h2>
                        </div>
                        <span class="material-symbols-outlined display-4 opacity-50">groups</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-0 bg-info text-white h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase fw-bold opacity-75">Profesionales</h6>
                            <h2 class="display-5 fw-bold mb-0"><%= stats.profesionales %></h2>
                        </div>
                        <span class="material-symbols-outlined display-4 opacity-50">stethoscope</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white pt-4 pb-3 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-secondary mb-0">Gestión de Citas</h5>
                <a href="/admin/citas/nueva" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-6">add_circle</span> Agendar Cita Manual
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha y Hora</th>
                                <th>Paciente</th>
                                <th>Procedimiento</th>
                                <th>Profesional</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(typeof citas !== 'undefined' && citas.length > 0) { %>
                                <% citas.forEach(cita => { %>
                                    <tr>
                                        <td>
                                            <strong><%= new Date(cita.fecha).toLocaleDateString('es-ES') %></strong><br>
                                            <small class="text-muted"><%= cita.hora.substring(0, 5) %> hrs</small>
                                        </td>
                                        <td><%= cita.paciente_nombre %> <%= cita.paciente_apellidos %></td>
                                        <td><%= cita.procedimiento %></td>
                                        <td>Dr/a. <%= cita.doc_apellidos %></td>
                                        <td>
                                            <% if(cita.estado === 'pendiente') { %>
                                                <span class="badge bg-warning text-dark d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined" style="font-size: 14px;">pending_actions</span> Pendiente</span>
                                            <% } else if(cita.estado === 'completada') { %>
                                                <span class="badge bg-success d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span> Completada</span>
                                            <% } else { %>
                                                <span class="badge bg-danger d-inline-flex align-items-center gap-1"><span class="material-symbols-outlined" style="font-size: 14px;">cancel</span> Cancelada</span>
                                            <% } %>
                                        </td>
                                        <td class="text-center">
                                            <a href="/admin/citas/editar/<%= cita.id_cita %>" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center justify-content-center" title="Editar">
                                                <span class="material-symbols-outlined fs-6">edit</span>
                                            </a>
                                            <form action="/admin/citas/eliminar/<%= cita.id_cita %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center justify-content-center" title="Eliminar" onclick="return confirm('¿Seguro que deseas eliminar esta cita?')">
                                                    <span class="material-symbols-outlined fs-6">delete</span>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <span class="material-symbols-outlined display-3 opacity-25 d-block mb-2">event_busy</span>
                                        No hay citas registradas en el sistema.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <%- include ('../partials/footer') %>
</body>
</html>